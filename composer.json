{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "thelemon2020/pest-plugin-pom",
    "authors": [{"name": "Chris Lemon"}],
    "description": "A Pest plugin for writing browser tests using the Page Object Model.",
    "keywords": [
        "pest",
        "plugin",
        "browser",
        "testing",
        "page-object-model"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Thelemon2020\\PestPom\\": "src/"
        },
        "files": ["src/Autoload.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Thelemon2020\\PestPom\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Thelemon2020\\PestPom\\PestPomServiceProvider"
            ]
        },
        "pest": {
            "plugins": [
                "Thelemon2020\\PestPom\\Plugin"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}